# Atlas (mongodb+srv) — recommended for this demo
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=MyApp
MONGODB_DB=mdba_demo

# Local MongoDB (optional)
# MONGODB_URI=mongodb://localhost:27017

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: enables natural-language workflow design via OpenAI (otherwise heuristic demo brain)
# OPENAI_API_KEY=sk-...

# Optional: Atlas Admin API (service account OAuth) — GET /api/atlas/status smoke test
# ATLAS_CLIENT_ID=mdb_sa_id_...
# ATLAS_CLIENT_SECRET=mdb_sa_sk_...

# Optional: override Agent Skills source (defaults: mongodb/agent-skills, branch main)
# AGENT_SKILLS_REPO=mongodb/agent-skills
# AGENT_SKILLS_BRANCH=main
